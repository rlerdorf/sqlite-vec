{
    "name": "sqlite-vec/sqlite-vec",
    "description": "PHP bindings for sqlite-vec: vector search for SQLite",
    "type": "library",
    "license": ["MIT", "Apache-2.0"],
    "keywords": ["sqlite", "vector", "search", "embedding", "knn"],
    "homepage": "https://github.com/rlerdorf/sqlite-vec",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0"
    },
    "suggest": {
        "ext-pdo_sqlite": "For zero-config extension loading on PHP 8.4+",
        "ext-sqlite3": "For SQLite3 class usage (requires sqlite-vec-setup)"
    },
    "autoload": {
        "psr-4": {
            "SqliteVec\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SqliteVec\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/sqlite-vec-setup"
    ]
}
